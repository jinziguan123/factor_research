# LLM 因子助手（OpenAI 兼容协议，中转 / 官方都行）
# 不配置 OPENAI_API_KEY 时，/api/factor_assistant/* 直接返回 503
#OPENAI_API_KEY=sk-XEA3N2olKri78I6O1byKfFUdvBS7SnhuAob45BsbmI6zr6R6
#OPENAI_BASE_URL=https://codeflow.asia/v1
#OPENAI_MODEL=gpt-5.4
OPENAI_API_KEY=sk-09b042f2a54d49a8813c4383e98f0ae0
OPENAI_BASE_URL=https://api.deepseek.com/anthropic
OPENAI_MODEL=deepseek-v4-pro[1m]
OPENAI_TIMEOUT_S=60
# LLM HTTP 协议：chat_completions（gpt-4o/4o-mini 等 chat 模型）/ responses（o1/o3/gpt-5 等 reasoning 模型）
#  ┌────────────────────┬─────────────────────────┬───────────────────────────┬─────────────────────────┐
#  │        协议        │           URL           │          请求体           │          适用           │
#  ├────────────────────┼─────────────────────────┼───────────────────────────┼─────────────────────────┤
#  │ chat_completions   │ {base}/chat/completions │ {model, messages}         │ OpenAI 标准             │
#  ├────────────────────┼─────────────────────────┼───────────────────────────┼─────────────────────────┤
#  │ responses          │ {base}/responses        │ {model, input}            │ o1/o3/gpt-5             │
#  ├────────────────────┼─────────────────────────┼───────────────────────────┼─────────────────────────┤
#  │ anthropic_messages │ {base}/messages         │ {model, messages, system} │ DeepSeek Anthropic 兼容 │
#  └────────────────────┴─────────────────────────┴───────────────────────────┴─────────────────────────┘
OPENAI_API_PROTOCOL=anthropic_messages
# 是否带 JSON 响应格式约束；默认 true，少数老代理不兼容时可关掉走 prompt 约束
OPENAI_RESPONSE_FORMAT_JSON=true
# 多因子合成LightGBM相关参数
FR_LGB_DEVICE=auto
FR_TASK_WORKERS=1